# Required: Groq API key for Llama (email categorization, writing, proofreading)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Skip emails from this address (your own email)
# If not set, no emails will be skipped based on sender
MY_EMAIL=your.email@gmail.com

# Optional: Only needed if running create_index.py test with Gemini
# GOOGLE_API_KEY=your_google_api_key_here

# Web app: OAuth redirect URI (must match Google Cloud Console)
# OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
